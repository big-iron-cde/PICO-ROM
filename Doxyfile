# Doxygen configuration for the Pico-as-ROM project.
# Run from the repo root:  doxygen
# Output: ./html  (open html/index.html)

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "Pico-as-ROM"
PROJECT_BRIEF          = "A Raspberry Pi Pico 2 as ROM + clock for a W65C02S CPU"
OUTPUT_DIRECTORY       =
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
# Firmware C sources + the README as the landing page.
INPUT                  = pico-rom-test README.md
FILE_PATTERNS          = *.c *.h *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Keep unrelated / generated trees out.
EXCLUDE                = pico-u2f docs .docs-venv html latex bin

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = YES
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
GENERATE_LATEX         = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Diagrams
#---------------------------------------------------------------------------
HAVE_DOT               = NO

#---------------------------------------------------------------------------
# Misc
#---------------------------------------------------------------------------
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
